# LLM Provider Configuration
# Supported: openai | azure-openai | claude | ollama
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1
# LLM_API_KEY=          # Required for openai, azure-openai, claude
# LLM_ENDPOINT=         # Required for azure-openai, ollama (default: http://localhost:11434)
# AZURE_DEPLOYMENT_NAME= # Required for azure-openai

# Server Configuration
HOST=127.0.0.1
PORT=3000
